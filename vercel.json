{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install --prefix portfolio-website",
  "buildCommand": "npm run build --prefix portfolio-website",
  "outputDirectory": "portfolio-website/build",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
