# Copy to `.env.local` for local builds. On Vercel: Project Settings → Environment Variables → redeploy.

# Option A — EmailJS (template must send to minasesek@gmail.com in the dashboard)
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_EMAILJS_PUBLIC_KEY=

# Option B — Web3Forms (https://web3forms.com — set inbox there, restrict domain to misemillustration.com)
REACT_APP_WEB3FORMS_ACCESS_KEY=
